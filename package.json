{
	"name": "steam-screenshot-importer",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"screenshots": "vite build --mode example && playwright test",
		"check": "svelte-check-rs --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check-rs --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tauri-apps/cli-cef": "3.0.0-alpha.6",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^26.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check-rs": "^0.10.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@types/canvas-confetti": "^1.9.0",
		"canvas-confetti": "^1.9.4",
		"dompurify": "^3.4.12",
		"fuse.js": "^7.4.2",
		"marked": "^18.0.6",
		"svelte-hamburgers": "^5.0.0",
		"svelte-spa-router": "^5.1.1",
		"sweetalert2": "^11.26.25",
		"vanilla-tilt": "^1.8.1"
	}
}
