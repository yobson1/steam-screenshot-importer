{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"build": {
		"beforeBuildCommand": "npm run build",
		"beforeDevCommand": "npm run dev",
		"frontendDist": "../public",
		"devUrl": "http://localhost:3000"
	},
	"bundle": {
		"active": true,
		"category": "Utility",
		"copyright": "",
		"targets": "msi",
		"externalBin": [],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
