{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"build": {
		"beforeBuildCommand": "pnpm fetch-steamworks && pnpm build",
		"beforeDevCommand": "pnpm fetch-steamworks && pnpm dev",
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173"
	},
	"bundle": {
		"active": true,
		"category": "Utility",
		"targets": ["msi", "deb", "appimage"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/256x256.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"shortDescription": "Automates importing images to steam screenshots",
		"linux": {
			"deb": {
				"desktopTemplate": "template.desktop"
			}
		}
	},
	"productName": "steam-screenshot-importer",
	"mainBinaryName": "steam-screenshot-importer",
	"identifier": "com.yobson.ssi",
	"app": {
		"windows": [
			{
				"fullscreen": false,
				"height": 780,
				"resizable": true,
				"title": "Steam Screenshot Importer",
				"width": 1370,
				"useHttpsScheme": true
			}
		]
	}
}
