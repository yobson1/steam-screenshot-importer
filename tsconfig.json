{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"types": ["vite/client", "node"]
	},
	"include": [
		"src/**/*.d.ts",
		"src/**/*.ts",
		"src/**/*.svelte",
		"tests/**/*.ts",
		"vite/**/*.ts",
		"playwright.config.ts"
	],
	"exclude": ["node_modules/*", "public/*", "pkg/**", "src/**/*.js"]
}
